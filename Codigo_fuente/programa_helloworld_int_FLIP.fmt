120  27              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
121  27              ;clk=50MHz, 460800bps, cont1= 01, cont2= 0A
122  27              ;1 + (1 + 1*(1 + 10*2 + 2)) + 1 = 26; aprox = 27,125
123  27              ;clk=50MHz, 921600bps, cont1=01, cont2=04 NO FUNCIONA
124  27              ;1 + (1 + 1*(1 + 4*2 + 2)) + 1 = 14; aprox = 13,56
125  27 WAIT_05BIT   :LOAD       CONT1        03           
126  28 ESPERA4      :LOAD       CONT2        10           
