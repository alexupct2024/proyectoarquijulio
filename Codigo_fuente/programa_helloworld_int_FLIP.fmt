113  27              ;1 + (1 + 3*(1 + 27*2 + 2)) + 1 = 1298; aprox = 173.6
114  27              ;clk=50MHz, 115200bps, cont1=03, cont2=10
115  27              ;1 + (1 + 3*(1 + 16*2 + 2)) + 1 = 108; aprox = 108.5
116  27              ;clk=50MHz, 230400bps, cont1= 03, cont2= 07
117  27              ;1 + (1 + 3*(1 + 7*2 + 2)) + 1 = 54; aprox = 54,25
118  27              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
