116  2B              ;1 + (1 + 3*(1 + 27*2 + 2)) + 1 = 1298; aprox = 173.6
117  2B              ;clk=50MHz, 115200bps, cont1=03, cont2=10
118  2B              ;1 + (1 + 3*(1 + 16*2 + 2)) + 1 = 108; aprox = 108.5
