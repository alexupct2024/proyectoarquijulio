  1   0              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  2   0              ;                 
  3   0              ;Transmision RS-232 por software. 
  4   0              ;115200bps, 8 data bits, no parity, 1 stop bit, no flow control,
  5   0              ;parte1: transmite por el puerte serie el contenido de la memoria RAM (64 bytes, portid [0-63])
  6   0              ;parte2: genera numeros pseudo-aleatorios, bucle contador+interrupcion para transmitir numero.
  7   0              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  8   0              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  9   0              ;declaracion de constantes y variables
 10   0              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;                  
 11   0              :CONSTANT   RS232        FF           ; puerto comunicacion serie es el FF
 12   0              :CONSTANT   PARITY_DATA  FD           
 13   0              :CONSTANT   PARITY_RESULT FE           
 14   0              ; rx es el bit 0 del puerto FF(entrada)
 15   0              ; tx es el bit 7 del puerto FF(salida), esto es porque
 16   0              ;el hyperterminal envia primero el LSB, por eso vamos desplazando a la 
 17   0              ;izquierda al recibir, y al enviar tambien, con lo que enviamos de nuevo
 18   0              ;el LSB primero como corresponde para que lo entienda el hyperterminal
 19   0              :NAMEREG    S1           TXREG        ;buffer de transmision
 20   0              :NAMEREG    S2           RXREG        ;buffer de recepcion
 21   0              :NAMEREG    S3           CONTBIT      ;contador de los 8 bits de datos
 22   0              :NAMEREG    S4           CONT1        ;contador de retardo1
 23   0              :NAMEREG    S5           CONT2        ;contador de retardo2
 24   0              ;
 25   0              
 26   0              :ADDRESS    00           
 27   0              
 28   0              :DISABLE    INTERRUPT    
 29   1              
 30   1 START        
 31   1              :LOAD       S0           43           
 32   2              :SWAP       S0           
 33   3              :LOAD       TXREG        S0           
 34   4              :CALL       TRANSMITE    
 35   5              
 36   5 FIN          
 37   5              :JUMP       FIN          
 38   6              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 39   6              ;Rutina de recepcion de caracteres
 40   6              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 41   6 RECIBE       ;esperamos a que se reciba un bit de inicio
 42   6              :INPUT      RXREG        RS232        
 43   7              :AND        RXREG        80           
 44   8              :JUMP       NZ           RECIBE       
 45   9              :CALL       WAIT_05BIT   
 46   A              ;almacenamos los 8 bits de datos
 47   A              :LOAD       CONTBIT      09           
 48   B NEXT_RX_BIT  :CALL       WAIT_1BIT    
 49   C              :SR0        RXREG        
 50   D              :INPUT      S0           RS232        
 51   E              :AND        S0           80           
 52   F              :OR         RXREG        S0           
 53  10              :SUB        CONTBIT      01           
 54  11              :JUMP       NZ           NEXT_RX_BIT  
 55  12              :RETURN     
 56  13              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 57  13              ;Rutina de transmision de caracteres
 58  13              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 59  13 TRANSMITE    ;enviamos un bit de inicio
 60  13              :LOAD       S0           00           
 61  14              :OUTPUT     S0           RS232        
 62  15              :CALL       WAIT_1BIT    
 63  16              ;enviamos los 8 bits de datos
 64  16              :LOAD       CONTBIT      08           
 65  17 NEXT_TX_BIT  :OUTPUT     TXREG        RS232        
 66  18              :CALL       WAIT_1BIT    
 67  19              :SR0        TXREG        
 68  1A              :SUB        CONTBIT      01           
 69  1B              :JUMP       NZ           NEXT_TX_BIT  
 70  1C              ;enviamos un bit de parada
 71  1C              :LOAD       S0           FF           
 72  1D              :OUTPUT     S0           RS232        
 73  1E              :CALL       WAIT_1BIT    
 74  1F              :RETURN     
 75  20              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 76  20              ;Rutina espera 1 bit (a 9600bps)
 77  20              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 78  20              ;clk=50MHz, 9600bps, cont1=0A, cont2=80
 79  20              ;esta rutina ejecuta 1 + (1 + 10*(1 + 128*2 + 2)) + 1 = 2593 instruciones,
 80  20              ;aproximandose al numero teorico de (104,16us/bit)/(0,04 us/instruc) = 2604,166 instr/bit necesarias.
 81  20              ;clk=40MHz, 57600bps, cont1=05, cont2=21
 82  20              ;esta rutina ejecuta 1 + (1 + 5*(1 + 33*2 + 2)) + 1 =  instruciones,
 83  20              ;aproximandose al numero teorico de (17,36us/bit)/(0,05 us/instruc) = 347,2 instr/bit necesarias.
 84  20              ;clk=50MHz, 115200bps, cont1=03, cont2=22
 85  20              ;esta rutina ejecuta 1 + (1 + 3*(1 + 34*2 + 2)) + 1 = 216 instruciones,
 86  20              ;aproximandose al numero teorico de (8,68us/bit)/(0,04 us/instruc) = 217 instr/bit necesarias.
 87  20              ;clk=50MHz, 230400bps, cont1= 03, cont2= 10
 88  20              ;esta rutina ejecuta 1 + (1 + 3*(1 + 16*2 + 2)) + 1 = 108 instruciones,
 89  20              ;aproximandose al numero teorico de (4,34us/bit)/(0,04 us/instruc) = 108,5 instr/bit necesarias.
 90  20              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 91  20              ;OJO: con el USB2COM no he conseguido pasar de los 230400bps bien. 
 92  20              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 93  20              ;clk=50MHz, 460800bps, cont1= 03, cont2=06 OJO:Hay que ponerle 1 menos a cont2 y que tome 
 94  20              ;caracteres ascii de 7 bits para que funcione.
 95  20              ;esta rutina ejecuta 1 + (1 + 3*(1 + 7*2 + 2)) + 1 = 54 instruciones,
 96  20              ;aproximandose al numero teorico de (2,17us/bit)/(0,04 us/instruc) = 54,25 instr/bit necesarias.
 97  20              ;clk=50MHz, 921600bps, cont1=01, cont2=0A NO FUNCIONA
 98  20              ;esta rutina ejecuta 1 + (1 + 1*(1 + 10*2 + 2)) + 1 = 26 instruciones,
 99  20              ;aproximandose al numero teorico de (1,085us/bit)/(0,04 us/instruc) = 27,127 instr/bit necesarias.
100  20 WAIT_1BIT    :LOAD       CONT1        03           
101  21 ESPERA2      :LOAD       CONT2        22           
102  22 ESPERA1      :SUB        CONT2        01           
103  23              :JUMP       NZ           ESPERA1      
104  24              :SUB        CONT1        01           
105  25              :JUMP       NZ           ESPERA2      
106  26              :RETURN     
