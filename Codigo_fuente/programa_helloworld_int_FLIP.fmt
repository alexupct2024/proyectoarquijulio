  1   0              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  2   0              ;                 
  3   0              ;Transmision RS-232 por software. 
  4   0              ;115200bps, 8 data bits, no parity, 1 stop bit, no flow control,
  5   0              ;parte1: transmite por el puerte serie el contenido de la memoria RAM (64 bytes, portid [0-63])
  6   0              ;parte2: genera numeros pseudo-aleatorios, bucle contador+interrupcion para transmitir numero.
  7   0              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  8   0              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  9   0              ;declaracion de constantes y variables
 10   0              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;                  
 11   0              :CONSTANT   RS232        FF           ; puerto comunicacion serie es el FF
 12   0              :CONSTANT   PARITY_DATA  FD           
 13   0              :CONSTANT   PARITY_RESULT FE           
 14   0              ; rx es el bit 0 del puerto FF(entrada)
 15   0              ; tx es el bit 7 del puerto FF(salida), esto es porque
 16   0              ;el hyperterminal envia primero el LSB, por eso vamos desplazando a la 
 17   0              ;izquierda al recibir, y al enviar tambien, con lo que enviamos de nuevo
 18   0              ;el LSB primero como corresponde para que lo entienda el hyperterminal
 19   0              :NAMEREG    S1           TXREG        ;buffer de transmision
 20   0              :NAMEREG    S2           RXREG        ;buffer de recepcion
 21   0              :NAMEREG    S3           CONTBIT      ;contador de los 8 bits de datos
 22   0              :NAMEREG    S4           CONT1        ;contador de retardo1
 23   0              :NAMEREG    S5           CONT2        ;contador de retardo2
 24   0              ;
 25   0              
 26   0              
 27   0              :ADDRESS    00           
 28   0              
 29   0              :DISABLE    INTERRUPT    
 30   1              
 31   1 START        :CALL       RECIBE       
 32   2              :LOAD       S0           RXREG        
 33   3              :MASK       S0           
 34   4              :OUTPUT     S0           FD           
 35   5              :INPUT      S0           FE           
 36   6              :ADD        S0           30           
 37   7              :LOAD       TXREG        S0           
 38   8              :CALL       TRANSMITE    
 39   9              :JUMP       START        
 40   A              
 41   A              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 42   A              ; Rutina de recepcion de caracteres
 43   A              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 44   A RECIBE       ;esperamos a que se reciba un bit de inicio
 45   A              :INPUT      RXREG        RS232        
 46   B              :AND        RXREG        80           
 47   C              :JUMP       NZ           RECIBE       
 48   D              :CALL       WAIT_05BIT   
 49   E              ;almacenamos los 8 bits de datos
 50   E              :LOAD       CONTBIT      09           
 51   F NEXT_RX_BIT  :CALL       WAIT_1BIT    
 52  10              :SR0        RXREG        
 53  11              :INPUT      S0           RS232        
 54  12              :AND        S0           80           
 55  13              :OR         RXREG        S0           
 56  14              :SUB        CONTBIT      01           
 57  15              :JUMP       NZ           NEXT_RX_BIT  
 58  16              :RETURN     
 59  17              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 60  17              ;Rutina de transmision de caracteres
 61  17              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 62  17 TRANSMITE    ;enviamos un bit de inicio
 63  17              :LOAD       S0           00           
 64  18              :OUTPUT     S0           RS232        
 65  19              :CALL       WAIT_1BIT    
 66  1A              ;enviamos los 8 bits de datos
 67  1A              :LOAD       CONTBIT      08           
 68  1B NEXT_TX_BIT  :OUTPUT     TXREG        RS232        
 69  1C              :CALL       WAIT_1BIT    
 70  1D              :SR0        TXREG        
 71  1E              :SUB        CONTBIT      01           
 72  1F              :JUMP       NZ           NEXT_TX_BIT  
 73  20              ;enviamos un bit de parada
 74  20              :LOAD       S0           FF           
 75  21              :OUTPUT     S0           RS232        
 76  22              :CALL       WAIT_1BIT    
 77  23              :RETURN     
 78  24              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 79  24              ;Rutina espera 1 bit (a 9600bps)
 80  24              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 81  24              ;clk=50MHz, 9600bps, cont1=0A, cont2=80
 82  24              ;esta rutina ejecuta 1 + (1 + 10*(1 + 128*2 + 2)) + 1 = 2593 instruciones,
 83  24              ;aproximandose al numero teorico de (104,16us/bit)/(0,04 us/instruc) = 2604,166 instr/bit necesarias.
 84  24              ;clk=40MHz, 57600bps, cont1=05, cont2=21
 85  24              ;esta rutina ejecuta 1 + (1 + 5*(1 + 33*2 + 2)) + 1 =  instruciones,
 86  24              ;aproximandose al numero teorico de (17,36us/bit)/(0,05 us/instruc) = 347,2 instr/bit necesarias.
 87  24              ;clk=50MHz, 115200bps, cont1=03, cont2=22
 88  24              ;esta rutina ejecuta 1 + (1 + 3*(1 + 34*2 + 2)) + 1 = 216 instruciones,
 89  24              ;aproximandose al numero teorico de (8,68us/bit)/(0,04 us/instruc) = 217 instr/bit necesarias.
 90  24              ;clk=50MHz, 230400bps, cont1= 03, cont2= 10
 91  24              ;esta rutina ejecuta 1 + (1 + 3*(1 + 16*2 + 2)) + 1 = 108 instruciones,
 92  24              ;aproximandose al numero teorico de (4,34us/bit)/(0,04 us/instruc) = 108,5 instr/bit necesarias.
 93  24              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 94  24              ;OJO: con el USB2COM no he conseguido pasar de los 230400bps bien. 
 95  24              ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
 96  24              ;clk=50MHz, 460800bps, cont1= 03, cont2=06 OJO:Hay que ponerle 1 menos a cont2 y que tome 
 97  24              ;caracteres ascii de 7 bits para que funcione.
 98  24              ;esta rutina ejecuta 1 + (1 + 3*(1 + 7*2 + 2)) + 1 = 54 instruciones,
 99  24              ;aproximandose al numero teorico de (2,17us/bit)/(0,04 us/instruc) = 54,25 instr/bit necesarias.
100  24              ;clk=50MHz, 921600bps, cont1=01, cont2=0A NO FUNCIONA
101  24              ;esta rutina ejecuta 1 + (1 + 1*(1 + 10*2 + 2)) + 1 = 26 instruciones,
102  24              ;aproximandose al numero teorico de (1,085us/bit)/(0,04 us/instruc) = 27,127 instr/bit necesarias.
103  24 WAIT_1BIT    :LOAD       CONT1        03           
104  25 ESPERA2      :LOAD       CONT2        22           
105  26 ESPERA1      :SUB        CONT2        01           
106  27              :JUMP       NZ           ESPERA1      
107  28              :SUB        CONT1        01           
108  29              :JUMP       NZ           ESPERA2      
109  2A              :RETURN     
